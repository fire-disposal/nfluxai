# Example .env for nfluxai
# Copy to .env and fill values, or set these as system env variables.

# Silicon Flow embeddings API
SILICON_FLOW_API_URL=https://api.siliconflow.cn/v1/embeddings
SILICON_FLOW_API_KEY=your_api_key_here
SILICON_FLOW_MODEL=BAAI/bge-m3

# DeepSeek LLM API key (optional)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

